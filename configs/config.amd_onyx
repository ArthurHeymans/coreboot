CONFIG_VENDOR_AMD=y
CONFIG_MAINBOARD_VENDOR="AMD"
CONFIG_MAINBOARD_PART_NUMBER="ONYX"
CONFIG_BOARD_AMD_ONYX=y
CONFIG_PAYLOAD_LINUXBOOT=y
CONFIG_LINUX_COMMAND_LINE="earlycon=uart,mmio32,0xfedca000 console=ttyS5,115200"
CONFIG_LINUXBOOT_COMPILE_KERNEL=y
CONFIG_LINUXBOOT_KERNEL_CUSTOM_CONFIG=y
CONFIG_LINUXBOOT_KERNEL_CONFIGFILE="x86_64/linuxboot_onyx_defconfig"
CONFIG_LINUXBOOT_BUILD_INITRAMFS=y
